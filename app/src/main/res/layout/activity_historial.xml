<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="76dp"
    android:paddingEnd="18dp"
    android:paddingBottom="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/titulo_historial"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="14dp"
        android:gravity="center"
        android:text="@string/subtitulo_historial"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <ListView
        android:id="@+id/listViewHistorial"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:divider="@drawable/list_divider_space"
        android:dividerHeight="12dp"
        android:fadeScrollbars="false"
        android:paddingStart="2dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:scrollbarSize="6dp"
        android:scrollbarStyle="insideInset"
        android:scrollbarThumbVertical="@drawable/bg_scrollbar_thumb"
        android:scrollbarTrackVertical="@drawable/bg_scrollbar_track"
        android:scrollbars="vertical" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverEncuesta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:minHeight="42dp"
            android:text="@string/ir_encuesta"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverInicioHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_secondary_button"
            android:minHeight="42dp"
            android:text="@string/volver_inicio"
            android:textColor="@color/brand_primary"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
